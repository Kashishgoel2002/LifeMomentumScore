---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---

<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
    {subtitle && <p class="mt-2 max-w-xl text-sm text-body">{subtitle}</p>}
  </div>
  <div class="shrink-0">
    <slot name="actions" />
  </div>
</div>
