---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Product',
    links: [
      { href: '/dashboard', label: 'Dashboard' },
      { href: '/habits', label: 'Habits' },
      { href: '/calendar', label: 'Calendar' },
      { href: '/review', label: 'Review' },
    ],
  },
  {
    title: 'Learn',
    links: [
      { href: '/features', label: 'Features' },
      { href: '/about', label: 'About' },
    ],
  },
];
---

<footer class="border-t border-hairline">
  <div class="container-page grid gap-10 py-16 sm:grid-cols-2 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2.5">
        <img src="/favicon.svg" width="28" height="28" class="h-7 w-7 rounded-md" alt="" aria-hidden="true" />
        <span class="text-sm font-medium tracking-tight">Life Momentum Score</span>
      </div>
      <p class="mt-4 max-w-xs text-sm text-body">
        Measure whether your daily actions create positive or negative momentum in your life.
      </p>
    </div>

    {cols.map((col) => (
      <div>
        <p class="eyebrow cursor-default select-none">{col.title}</p>
        <ul class="mt-4 space-y-2.5">
          {col.links.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-body transition-colors hover:text-ink hover:underline underline-offset-4">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-hairline">
    <div class="container-page flex flex-col gap-2 py-6 text-xs text-mute sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Life Momentum Score</p>
      <p class="font-mono">Data stays on your device · localStorage</p>
    </div>
  </div>
</footer>
