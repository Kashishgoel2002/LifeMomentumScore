---
interface Props {
  title: string;
  body: string;
  eyebrow?: string;
  /** Adds a subtle lift on hover. Used by marketing cards only. */
  hover?: boolean;
}
const { title, body, eyebrow, hover = false } = Astro.props;
---

<div class:list={['card p-6', hover && 'card-hover']}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h3 class="text-lg font-semibold tracking-tight text-ink">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-body">{body}</p>
  <slot />
</div>
