---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Calendar"
  description="Browse your behavioral history day by day. Click any date to view, add, edit, or delete its entries."
>
  <div class="container-page py-12 sm:py-16">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">History</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Calendar</h1>
        <p class="mt-2 max-w-xl text-sm text-body">A record of your behavior. Click any day to manage its entries.</p>
      </div>
      <div class="flex items-center gap-2">
        <button id="prev-month" class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-2" aria-label="Previous month" style="box-shadow: inset 0 0 0 1px var(--color-hairline);">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <span id="month-label" class="min-w-[10rem] text-center text-sm font-medium"></span>
        <button id="next-month" class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-2" aria-label="Next month" style="box-shadow: inset 0 0 0 1px var(--color-hairline);">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-5">
      <!-- Grid -->
      <div class="lg:col-span-3">
        <div id="weekday-row" class="grid grid-cols-7 gap-1.5 px-1 pb-2"></div>
        <div id="calendar-grid" class="grid grid-cols-7 gap-1.5"></div>
        <div class="mt-4 flex flex-wrap items-center gap-4 text-xs text-mute">
          <span class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-positive"></span> Net positive day</span>
          <span class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-negative"></span> Net negative day</span>
        </div>
      </div>

      <!-- Day detail -->
      <div class="lg:col-span-2">
        <div class="card p-5">
          <div class="flex items-center justify-between">
            <h2 id="day-title" class="text-sm font-medium text-ink">Select a day</h2>
            <span id="day-net" class="font-mono text-sm"></span>
          </div>

          <form id="add-entry-form" class="mt-4 hidden gap-2 sm:flex">
            <label for="entry-habit" class="sr-only">Habit</label>
            <select id="entry-habit" class="input flex-1"></select>
            <button type="submit" class="btn btn-primary btn-sm h-10 shrink-0">Add</button>
          </form>

          <ul id="day-entries" class="mt-4 space-y-2"></ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { store } from '../lib/store';
  import { signed, totals } from '../lib/score';
  import {
    toISODate, todayISO, prettyDate, startOfMonth, endOfMonth,
    monthName, weekdayLabels, addDays, startOfDay,
  } from '../lib/date';
  import type { Entry } from '../lib/types';

  const $ = (id: string) => document.getElementById(id)!;
  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

  let viewMonth = startOfMonth(new Date());
  let selected = todayISO();
  const settings = store.getSettings();

  // Weekday header
  $('weekday-row').innerHTML = weekdayLabels(settings.weekStartsOn)
    .map((d) => `<div class="text-center text-xs font-medium text-mute">${d}</div>`)
    .join('');

  function entriesByDate(): Map<string, Entry[]> {
    const map = new Map<string, Entry[]>();
    for (const e of store.getEntries()) {
      (map.get(e.date) ?? map.set(e.date, []).get(e.date)!).push(e);
    }
    return map;
  }

  function renderGrid() {
    const first = startOfMonth(viewMonth);
    const last = endOfMonth(viewMonth);
    $('month-label').textContent = `${monthName(first)} ${first.getFullYear()}`;

    const lead = (first.getDay() - settings.weekStartsOn + 7) % 7;
    const start = addDays(first, -lead);
    const byDate = entriesByDate();
    const today = todayISO();

    // Whole weeks needed to cover the lead-in + every day of the month.
    const totalCells = Math.ceil((lead + last.getDate()) / 7) * 7;
    const cells: string[] = [];
    let cursor = start;
    for (let i = 0; i < totalCells; i++) {
      const iso = toISODate(cursor);
      const inMonth = cursor.getMonth() === first.getMonth();
      const isFuture = startOfDay(cursor).getTime() > startOfDay(new Date()).getTime();
      const dayEntries = byDate.get(iso) ?? [];
      const net = totals(dayEntries).net;
      const hasEntries = dayEntries.length > 0;
      const dot = hasEntries
        ? `<span class="mx-auto mt-1 block h-1.5 w-1.5 rounded-full ${net > 0 ? 'bg-positive' : net < 0 ? 'bg-negative' : 'bg-mute'}"></span>`
        : `<span class="mx-auto mt-1 block h-1.5 w-1.5"></span>`;
      const isSel = iso === selected;
      const isToday = iso === today;

      cells.push(`
        <button data-date="${iso}"
          class="day-cell aspect-square rounded-md p-1.5 text-center transition-colors ${inMonth ? 'text-ink' : 'text-mute/50'} ${isSel ? 'bg-surface-2' : 'hover:bg-surface-2'} ${isFuture ? 'opacity-40' : ''}"
          style="box-shadow: inset 0 0 0 1px ${isSel ? 'var(--color-hairline-strong)' : 'transparent'};"
          aria-pressed="${isSel}" aria-label="${prettyDate(iso)}${hasEntries ? `, net ${signed(net)}` : ''}">
          <span class="text-sm ${isToday ? 'font-semibold' : ''} ${isToday ? 'underline underline-offset-4 decoration-ink' : ''}">${cursor.getDate()}</span>
          ${dot}
        </button>`);

      cursor = addDays(cursor, 1);
    }
    $('calendar-grid').innerHTML = cells.join('');
  }

  function renderDay() {
    const entries = store.getEntriesForDate(selected);
    const net = totals(entries).net;
    $('day-title').textContent = prettyDate(selected);
    const netEl = $('day-net');
    if (entries.length) {
      netEl.textContent = signed(net);
      netEl.className = `font-mono text-sm ${net > 0 ? 'text-positive' : net < 0 ? 'text-negative' : 'text-ink'}`;
    } else {
      netEl.textContent = '';
    }

    // Populate habit select
    const form = $('add-entry-form') as HTMLFormElement;
    form.classList.remove('hidden');
    form.classList.add('flex');
    const select = $('entry-habit') as HTMLSelectElement;
    const habits = store.getEnabledHabits();
    select.innerHTML = habits.length
      ? habits.map((h) => `<option value="${h.id}">${esc(h.name)} (${signed(h.score)})</option>`).join('')
      : `<option value="" disabled>No enabled habits</option>`;

    if (!entries.length) {
      $('day-entries').innerHTML = `<li class="rounded-lg border border-dashed border-hairline p-6 text-center text-sm text-mute">No entries for this day. Add one above.</li>`;
      return;
    }

    $('day-entries').innerHTML = entries.map((e) => {
      const tone = e.score >= 0 ? 'text-positive' : 'text-negative';
      return `<li class="card flex items-center gap-3 p-3" data-id="${e.id}">
          <span class="h-2 w-2 shrink-0 rounded-full ${e.score >= 0 ? 'bg-positive' : 'bg-negative'}"></span>
          <span class="min-w-0 flex-1 truncate text-sm">${esc(e.habitName)}</span>
          <input class="score-edit input h-8 w-16 shrink-0 text-center font-mono ${tone}" type="number" value="${e.score}" min="-50" max="50" step="1" aria-label="Edit score for ${esc(e.habitName)}" />
          <span class="font-mono text-xs text-mute">${e.time}</span>
          <button class="del-entry grid h-8 w-8 place-items-center rounded-md text-mute transition-colors hover:bg-negative-soft hover:text-negative" aria-label="Delete ${esc(e.habitName)} entry">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </button>
        </li>`;
    }).join('');
  }

  function renderAll() { renderGrid(); renderDay(); }

  // Navigation
  $('prev-month').addEventListener('click', () => { viewMonth = startOfMonth(addDays(startOfMonth(viewMonth), -1)); renderGrid(); });
  $('next-month').addEventListener('click', () => { viewMonth = startOfMonth(addDays(endOfMonth(viewMonth), 1)); renderGrid(); });

  $('calendar-grid').addEventListener('click', (e) => {
    const cell = (e.target as HTMLElement).closest('.day-cell') as HTMLElement | null;
    if (!cell) return;
    selected = cell.dataset.date!;
    renderAll();
  });

  $('add-entry-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const select = $('entry-habit') as HTMLSelectElement;
    if (!select.value) return;
    store.logHabit(select.value, selected);
  });

  $('day-entries').addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest('li[data-id]') as HTMLElement | null;
    if (!li) return;
    if ((e.target as HTMLElement).closest('.del-entry')) store.deleteEntry(li.dataset.id!);
  });

  $('day-entries').addEventListener('change', (e) => {
    const li = (e.target as HTMLElement).closest('li[data-id]') as HTMLElement | null;
    if (!li) return;
    const target = e.target as HTMLInputElement;
    if (target.classList.contains('score-edit')) {
      const score = parseInt(target.value, 10);
      if (!Number.isNaN(score)) store.updateEntry(li.dataset.id!, { score });
    }
  });

  store.onChange(renderAll);
  renderAll();
</script>
