---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/marketing/FeatureCard.astro';

const modes = [
  {
    name: 'Live Mode',
    tag: 'Default',
    body: 'See everything in real time — current score, positive points, negative points, and running totals as you log.',
  },
  {
    name: 'Weekly Reveal',
    tag: 'Reflective',
    body: 'Your score stays hidden during the week. You only see entries logged and days tracked. The number unlocks once the week ends.',
  },
  {
    name: 'Monthly Reveal',
    tag: 'Long view',
    body: 'The same delayed mechanic across a full month — the deepest reduction of daily bias for honest self-reflection.',
  },
];

const capabilities = [
  { title: 'Default habit library', body: '17 curated habits with sensible default scores, split across positive and negative behaviors.' },
  { title: 'Fully customizable', body: 'Edit any score, disable habits you don’t use, and create your own with custom point values.' },
  { title: 'Daily logging', body: 'Log actions in a tap. Every entry records the habit, score, type, date and time.' },
  { title: 'Calendar history', body: 'Click any day to view, edit, or delete its entries. The app becomes a record of your behavior.' },
  { title: 'Score categories', body: 'Six momentum bands translate a raw number into a meaning you can act on.' },
  { title: 'Private by default', body: 'Everything lives in your browser’s localStorage. Nothing is uploaded anywhere.' },
];
---

<Layout
  title="Features"
  description="Three tracking modes, a customizable habit library, daily logging, and a calendar history — all private to your browser."
>
  <section class="container-page py-20 text-center sm:py-24">
    <p class="eyebrow">Features</p>
    <h1 class="mx-auto mt-3 max-w-2xl text-4xl font-semibold tracking-tight sm:text-5xl">
      Everything you need to read your momentum.
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-lg text-body">
      Analytical, reflective, and private. Built to surface the cumulative impact of both your good
      and bad habits.
    </p>
  </section>

  <!-- Modes -->
  <section class="border-y border-hairline bg-surface/30">
    <div class="container-page py-20 sm:py-24">
      <div class="max-w-2xl">
        <p class="eyebrow">Three modes</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight">Choose how honest you want to be.</h2>
        <p class="mt-4 text-base text-body">
          Delayed score reveals help reduce daily bias and encourage more honest self-reflection.
        </p>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {modes.map((m) => (
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold tracking-tight">{m.name}</h3>
              <span class="badge">{m.tag}</span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-body">{m.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities grid -->
  <section class="container-page py-20 sm:py-24">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {capabilities.map((c) => (
        <FeatureCard title={c.title} body={c.body} />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a href="/dashboard" class="btn btn-primary inline-flex">Start Tracking</a>
    </div>
  </section>
</Layout>
