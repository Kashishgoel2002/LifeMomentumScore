---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Head back home or open your dashboard to keep tracking your momentum."
>
  <section class="container-page flex min-h-[60vh] items-center justify-center py-20 text-center sm:py-28">
    <div class="mx-auto max-w-lg">
      <p class="eyebrow">Error 404</p>
      <h1 class="mt-3 text-5xl font-semibold tracking-tight sm:text-6xl">Page not found.</h1>
      <p class="mx-auto mt-5 max-w-md text-lg leading-relaxed text-body">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/" class="btn btn-primary w-full sm:w-auto">Go Home</a>
        <a href="/dashboard" class="btn btn-secondary w-full sm:w-auto">Open Dashboard</a>
      </div>
    </div>
  </section>
</Layout>
