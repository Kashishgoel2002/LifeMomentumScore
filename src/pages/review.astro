---
import Layout from '../layouts/Layout.astro';
import ModeSwitcher from '../components/ModeSwitcher.astro';
---

<Layout
  title="Momentum Review"
  description="Reveal your Life Momentum Score. Live mode shows running totals; Weekly and Monthly modes unlock your momentum once the period ends — built for honest self-improvement."
>
  <div class="container-page py-12 sm:py-16">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="eyebrow">Review</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Momentum review</h1>
      </div>
      <ModeSwitcher />
    </div>

    <div id="mode-note" class="mt-6 rounded-lg bg-surface-2 p-4 text-sm text-body" style="box-shadow: inset 0 0 0 1px var(--color-hairline);"></div>

    <!-- Current period -->
    <section class="card relative mt-8 overflow-hidden p-6 sm:p-8">
      <div id="cur-mesh" class="pointer-events-none absolute inset-0 mesh-gradient opacity-[0.08]" aria-hidden="true"></div>
      <div id="current" class="relative"></div>
    </section>

    <!-- Daily breakdown (live mode only — reveal modes keep the score hidden) -->
    <section id="breakdown-section" class="mt-8 hidden">
      <h2 class="text-sm font-medium text-ink">Daily breakdown</h2>
      <p class="mt-1 text-xs text-body">See which days gained or lost momentum before opening the calendar.</p>
      <div id="breakdown" class="card mt-4 p-2 sm:p-3"></div>
    </section>

    <!-- Completed periods -->
    <section class="mt-10">
      <h2 class="text-sm font-medium text-ink">Completed periods</h2>
      <p class="mt-1 text-xs text-mute">Past periods are always revealed — this is where delayed scores unlock.</p>
      <div id="history" class="mt-5 grid gap-3 sm:grid-cols-2"></div>
    </section>
  </div>
</Layout>

<script>
  import { store } from '../lib/store';
  import { categoryFor, signed } from '../lib/score';
  import { currentWeek, currentMonth, pastWeeks, pastMonths, dailyNets, parseISO } from '../lib/periods';
  import type { Period } from '../lib/periods';

  const $ = (id: string) => document.getElementById(id)!;
  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  const dotFor = (tone: string) => tone === 'positive' ? 'bg-positive' : tone === 'negative' ? 'bg-negative' : 'bg-mute';

  const NOTES: Record<string, string> = {
    live: 'Live mode shows everything in real time — your current score, points, and running totals update as you log.',
    weekly: 'Weekly Reveal hides the current score. You see only activity until the week ends. Delayed score reveals help reduce daily bias and encourage more honest self-reflection.',
    monthly: 'Monthly Reveal hides the current score across the whole month. Delayed score reveals help reduce daily bias and encourage more honest self-reflection.',
  };

  function scoreBlock(period: Period, kindLabel: string): string {
    const cat = categoryFor(period.totals.net);
    const tone = cat.tone === 'positive' ? 'text-positive' : cat.tone === 'negative' ? 'text-negative' : 'text-ink';
    return `
      <p class="eyebrow">${kindLabel} · ${esc(period.label)}</p>
      <div class="mt-3 flex flex-wrap items-end gap-x-4 gap-y-2">
        <span class="text-5xl font-semibold tracking-tight ${tone} sm:text-6xl">${signed(period.totals.net)}</span>
        <span class="badge mb-2"><span class="h-1.5 w-1.5 rounded-full ${dotFor(cat.tone)}"></span>${cat.label}</span>
      </div>
      <div class="mt-5 flex flex-wrap gap-x-8 gap-y-2 text-sm">
        <div><span class="font-mono text-positive">${signed(period.totals.positive)}</span><span class="ml-1.5 text-mute">positive</span></div>
        <div><span class="font-mono text-negative">${period.totals.negative === 0 ? '0' : signed(period.totals.negative)}</span><span class="ml-1.5 text-mute">negative</span></div>
        <div><span class="font-mono text-ink">${period.totals.count}</span><span class="ml-1.5 text-mute">entries</span></div>
        <div><span class="font-mono text-ink">${period.daysTracked}</span><span class="ml-1.5 text-mute">days</span></div>
      </div>`;
  }

  function lockedBlock(period: Period, kindLabel: string): string {
    return `
      <p class="eyebrow">${kindLabel} · ${esc(period.label)}</p>
      <div class="mt-3 flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-full bg-surface-2" style="box-shadow: inset 0 0 0 1px var(--color-hairline);">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 7V5a4 4 0 018 0v2M3.5 7h9v6h-9z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <div>
          <p class="text-xl font-semibold tracking-tight">Hidden until this ${kindLabel.toLowerCase()} ends</p>
          <p class="text-sm text-mute">Keep logging — the score unlocks automatically.</p>
        </div>
      </div>
      <div class="mt-5 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-lg bg-surface-2 p-3" style="box-shadow: inset 0 0 0 1px var(--color-hairline);"><p class="font-mono text-xl text-ink">${period.totals.count}</p><p class="text-xs text-body">Entries</p></div>
        <div class="rounded-lg bg-surface-2 p-3" style="box-shadow: inset 0 0 0 1px var(--color-hairline);"><p class="font-mono text-xl text-ink">${period.daysTracked}</p><p class="text-xs text-body">Days tracked</p></div>
        <div class="rounded-lg bg-surface-2 p-3" style="box-shadow: inset 0 0 0 1px var(--color-hairline);"><p class="font-mono text-xl text-positive">${period.totals.positiveCount}</p><p class="text-xs text-body">Positive actions</p></div>
        <div class="rounded-lg bg-surface-2 p-3" style="box-shadow: inset 0 0 0 1px var(--color-hairline);"><p class="font-mono text-xl text-negative">${period.totals.negativeCount}</p><p class="text-xs text-body">Negative actions</p></div>
      </div>`;
  }

  const WEEKDAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const MONTHS_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

  function breakdownRows(period: Period): string {
    return dailyNets(period).map((d) => {
      const date = parseISO(d.date);
      const tone = d.net > 0 ? 'text-positive' : d.net < 0 ? 'text-negative' : 'text-mute';
      const value = d.net === 0 ? '0' : signed(d.net);
      return `<div class="flex items-center justify-between gap-3 px-3 py-2.5">
          <span class="text-sm text-body">
            <span class="text-ink">${WEEKDAYS[date.getDay()]}</span>
            <span class="ml-2 font-mono text-xs text-mute">${MONTHS_SHORT[date.getMonth()]} ${date.getDate()}</span>
          </span>
          <span class="font-mono text-sm ${tone}">${value}</span>
        </div>`;
    }).join('');
  }

  function historyCard(period: Period): string {
    const cat = categoryFor(period.totals.net);
    const tone = period.totals.net > 0 ? 'text-positive' : period.totals.net < 0 ? 'text-negative' : 'text-ink';
    return `<div class="card p-5">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-ink">${esc(period.label)}</p>
            <p class="mt-0.5 text-xs text-mute">${cat.label}</p>
          </div>
          <span class="text-2xl font-semibold tracking-tight ${tone}">${signed(period.totals.net)}</span>
        </div>
        <div class="mt-4 flex gap-5 text-xs text-mute">
          <span><span class="font-mono text-positive">${signed(period.totals.positive)}</span> pos</span>
          <span><span class="font-mono text-negative">${period.totals.negative === 0 ? '0' : signed(period.totals.negative)}</span> neg</span>
          <span><span class="font-mono text-body">${period.totals.count}</span> entries</span>
        </div>
        <details class="history-breakdown mt-4 border-t border-hairline pt-3">
          <summary class="flex cursor-pointer items-center justify-between gap-2 text-xs text-body transition-colors hover:text-ink">
            <span>View Daily Breakdown</span>
            <svg class="hb-icon shrink-0 text-mute" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="hb-body mt-2 divide-y divide-hairline">${breakdownRows(period)}</div>
        </details>
      </div>`;
  }

  function render() {
    const settings = store.getSettings();
    const mode = settings.trackingMode;
    const entries = store.getEntries();
    const isMonthly = mode === 'monthly';
    const kindLabel = isMonthly ? 'Month' : 'Week';
    const period = isMonthly ? currentMonth(entries) : currentWeek(entries, settings);

    $('mode-note').textContent = NOTES[mode];

    const breakdownSection = $('breakdown-section');
    if (mode === 'live') {
      $('cur-mesh').style.opacity = '0.12';
      $('current').innerHTML = scoreBlock(period, kindLabel);
      $('breakdown').innerHTML = `<div class="divide-y divide-hairline">${breakdownRows(period)}</div>`;
      breakdownSection.classList.remove('hidden');
    } else {
      $('cur-mesh').style.opacity = '0.05';
      $('current').innerHTML = lockedBlock(period, kindLabel);
      breakdownSection.classList.add('hidden');
    }

    const history = (isMonthly ? pastMonths(entries, 6) : pastWeeks(entries, settings, 6))
      .filter((p) => p.totals.count > 0);
    $('history').innerHTML = history.length
      ? history.map(historyCard).join('')
      : `<p class="text-sm text-mute">No completed periods with entries yet.</p>`;
  }

  store.onChange(render);
  render();
</script>
