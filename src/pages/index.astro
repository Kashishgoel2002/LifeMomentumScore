---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/marketing/FeatureCard.astro';
import CategoryLadder from '../components/CategoryLadder.astro';

const features = [
  {
    eyebrow: '01 / Net momentum',
    title: 'Both sides of the ledger',
    body: 'Your wins and your slip-ups land on the same scorecard. The number you see is the truth, net of everything — and a streak can never fake it.',
  },
  {
    eyebrow: '02 / Delayed reveal',
    title: 'Reduce daily bias',
    body: "Hide the score and unlock it weekly or monthly. When you can't chase a daily number, you finally log what actually happened.",
  },
  {
    eyebrow: '03 / A behavioral record',
    title: 'A calendar of your actions',
    body: 'Every action is timestamped and kept. Scroll back through any day and watch the real shape of your life come into focus.',
  },
];

const faqs = [
  {
    q: 'What is a habit tracker?',
    a: 'A habit tracker is a tool for recording the actions you repeat day to day — workouts, reading, sleep — so you can see your patterns over time. Most focus on streaks and completion rates.',
  },
  {
    q: 'How is Life Momentum Score different from a habit tracker?',
    a: 'Traditional trackers only count what you do well. Life Momentum Score weighs your positive and negative habits together and shows the net result, so you see your true direction — not just your wins.',
  },
  {
    q: 'Can I track bad habits as well as good habits?',
    a: 'Yes. Negative habits carry negative scores and subtract from your total. Logging them is the point — it reveals how much your good habits are actually moving the needle.',
  },
  {
    q: 'What is delayed score reveal?',
    a: 'In Weekly or Monthly mode your score stays hidden until the period ends. Removing the daily number reduces bias and helps you log honestly instead of optimizing for a figure.',
  },
  {
    q: 'Does my data stay private?',
    a: 'Completely. Everything is stored locally in your browser using localStorage. There are no accounts and no servers, so your data never leaves your device.',
  },
  {
    q: 'Can I create custom habits?',
    a: "Yes. Add your own habits with any score you choose, edit the default scores, disable the ones you don't use, and delete custom habits anytime.",
  },
  {
    q: 'What is a momentum score?',
    a: "Your momentum score is the sum of every habit you've logged in a period — positives minus negatives. It maps to six bands, from Negative Momentum to Thriving.",
  },
  {
    q: 'Is Life Momentum Score free?',
    a: 'Yes. Life Momentum Score is free and works instantly in your browser, with no sign-up and no backend.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const siteUrl = (Astro.site ?? new URL('https://lifemomentumscore.com')).href.replace(/\/$/, '');

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Life Momentum Score',
  applicationCategory: 'ProductivityApplication',
  operatingSystem: 'Web',
  url: siteUrl + '/',
  description:
    'A free habit tracker that weighs your positive and negative habits together and shows your net momentum — the true direction of your behavior over time.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  featureList: [
    'Track positive and negative habits',
    'Net momentum score across six bands',
    'Live, Weekly, and Monthly reveal modes',
    'Customizable habit library',
    'Private, on-device storage — no account required',
  ],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Life Momentum Score',
  url: siteUrl + '/',
  description:
    'Life Momentum Score is a private habit tracker that measures the net direction of your positive and negative habits.',
};
---

<Layout
  title="Life Momentum Score"
  description="Life Momentum Score is a free habit tracker that measures the direction of your life. Track positive and negative habits together and see your true momentum — private, on your device, no account needed."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-hairline">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[420px] mesh-gradient opacity-[0.22] blur-2xl"
      aria-hidden="true"
    >
    </div>
    <div class="container-page relative py-24 text-center sm:py-32">
      <h1 class="mx-auto max-w-3xl text-4xl font-semibold tracking-tight sm:text-6xl animate-rise">
        Measure the direction of your life.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-body animate-rise">
        Most people track good habits. Few measure the impact of bad ones.
        Life Momentum Score helps you understand your true trajectory.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/dashboard" class="btn btn-primary w-full sm:w-auto">Start Tracking</a>
        <a href="/features" class="btn btn-secondary w-full sm:w-auto">See how it works</a>
      </div>
    </div>
  </section>

  <!-- The core idea -->
  <section class="container-page py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">The problem</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        “I thought I had a productive week.”
      </h2>
      <p class="mt-5 text-base leading-relaxed text-body">
        Traditional habit trackers reward streaks and completion percentages — but they ignore the
        habits quietly working against you. Life Momentum Score asks a different question:
        <span class="text-ink">Where is your life actually heading?</span>
      </p>
    </div>

    <div class="mt-14 grid gap-4 md:grid-cols-3">
      {features.map((f) => (
        <FeatureCard eyebrow={f.eyebrow} title={f.title} body={f.body} hover />
      ))}
    </div>
  </section>

  <!-- Score categories -->
  <section class="border-y border-hairline bg-surface/30">
    <div class="container-page grid gap-12 py-20 sm:py-28 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="eyebrow">The scale</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Six bands of momentum.
        </h2>
        <p class="mt-5 max-w-md text-base leading-relaxed text-body">
          Your net score maps to a clear category — from Negative Momentum to Thriving. It is a
          mirror, not a leaderboard. The goal is awareness, not a high score.
        </p>
        <a href="/dashboard" class="btn btn-secondary btn-sm mt-7 inline-flex">Open your dashboard</a>
      </div>
      <CategoryLadder />
    </div>
  </section>

  <!-- CTA band (polarity-flipped dark) -->
  <section class="container-page py-20 sm:py-28">
    <div class="card relative overflow-hidden p-10 text-center sm:p-16">
      <div class="pointer-events-none absolute inset-0 mesh-gradient opacity-[0.14]" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="mx-auto max-w-xl text-3xl font-semibold tracking-tight sm:text-4xl">
          Start measuring your trajectory today.
        </h2>
        <p class="mx-auto mt-4 max-w-md text-base text-body">
          Free, private, and works instantly in your browser. No sign up, no backend.
        </p>
        <a href="/dashboard" class="btn btn-primary mt-8 inline-flex">Start Tracking</a>
      </div>
    </div>
  </section>

  <!-- Philosophy / short article -->
  <section class="border-t border-hairline">
    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-2xl">
        <p class="eyebrow">Philosophy</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Why direction beats completion.
        </h2>
        <div class="mt-6 space-y-5 text-base leading-relaxed text-body">
          <p>
            Most habit trackers are built around a single question: did you check the box? They
            count completions, celebrate streaks, and reward consistency. That's genuinely useful —
            but it only tells half the story. A flawless run of good habits can sit right beside a
            quiet pile of ones working against you, and a checkbox app will never let those two facts
            meet on the same page.
          </p>
          <p>
            Life Momentum Score starts from a different premise. What matters isn't how many boxes
            you ticked — it's the direction all of your behavior is pointing. Positive habits move
            you forward. Negative habits pull you back. Your momentum is simply the net of the two:
            the honest remainder once everything, good and bad, is counted together.
          </p>
          <p>
            That small reframing changes how a week reads. Three workouts don't quietly erase three
            late nights — they're weighed against them. The number stops being a trophy and becomes a
            compass: less about scoring well, more about noticing which way you're actually heading.
            Progress, in the end, isn't the absence of bad days. It's the accumulated direction of
            all your days, pointing somewhere on purpose.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-hairline">
    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-2xl">
        <p class="eyebrow">FAQ</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Questions, answered.
        </h2>

        <div class="faq mt-10 divide-y divide-hairline border-y border-hairline">
          {faqs.map((f) => (
            <details class="group">
              <summary class="flex items-center justify-between gap-4 py-5 text-base font-medium text-ink">
                {f.q}
                <svg
                  class="faq-icon shrink-0 text-mute"
                  width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"
                >
                  <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </summary>
              <p class="faq-answer pb-5 -mt-1 text-sm leading-relaxed text-body">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />
</Layout>
